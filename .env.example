DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_token"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="gere-um-segredo-longo"
GOOGLE_CLIENT_ID="google-oauth-client-id"
GOOGLE_CLIENT_SECRET="google-oauth-client-secret"

# E-mails autorizados a entrar no painel, separados por virgula.
ADMIN_EMAILS="voce@exemplo.com"

# Login por e-mail e senha. Gere o hash com:
# npm run admin:hash-password -- "sua-senha-forte"
ADMIN_PASSWORD_HASH="scrypt$salt$hash"
# Opcional apenas para teste/local se ainda nao gerou hash:
# ADMIN_PASSWORD="senha-temporaria"
